{
  "name": "the-book-author",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "db:generate": "node scripts/generate-prisma-clients.mjs",
    "db:push": "prisma db push",
    "db:push:hosted": "prisma db push --schema prisma/hosted.schema.prisma",
    "db:seed": "prisma db seed",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "npm run db:generate",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/client": "^6.17.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "prisma": "^6.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-textarea-autosize": "^8.5.9",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
